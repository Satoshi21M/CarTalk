{
  "name": "cartalk",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:server": "if [ -f .env ]; then node --env-file=.env server/index.mjs; else node --env-file=.env.example server/index.mjs; fi",
    "dev:all": "npm run start:server & npm run web",
    "dev:device": "npm run start:server & npx expo start --host lan",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@google/genai": "^1.47.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.5",
    "expo-constants": "~17.1.0",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-router": "~5.1.11",
    "expo-speech": "~13.1.7",
    "expo-speech-recognition": "^3.1.2",
    "expo-status-bar": "~2.2.3",
    "express": "^4.22.1",
    "firebase": "^11.10.0",
    "geofire": "^6.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
